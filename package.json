{
	"name": "@gabroberge/ts-json-as-const",
	"version": "2.0.0",
	"description": "A (very) simple CLI tool that reads JSON files and creates .d.ts files with their keys/values explicitly defined",
	"private": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"ts-json-as-const": "./dist/index.js"
	},
	"packageManager": "pnpm@9.1.4",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsup",
		"dev": "node dist/index.js",
		"format": "prettier --write \"**/*.{ts,json,md}\"",
		"lint": "concurrently --raw \"pnpm run lint:eslint\" \"pnpm run lint:typescript\"",
		"lint:eslint": "eslint \"**/*.{ts,json,md}\" --fix",
		"lint:typescript": "tsc",
		"test": "vitest run",
		"prepare": "husky",
		"release": "pnpm run build && changeset publish"
	},
	"keywords": [
		"typescript",
		"json",
		"const",
		"declaration",
		"declaration files"
	],
	"author": "Gabriel Roberge",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gabroberge/ts-json-as-const.git"
	},
	"homepage": "https://github.com/gabroberge/ts-json-as-const#readme",
	"bugs": "https://github.com/gabroberge/ts-json-as-const/issues",
	"pnpm": {
		"overrides": {
			"@typescript-eslint/utils": "^8.59.3"
		}
	},
	"peerDependencies": {
		"inflection": "^3.0.2",
		"isbinaryfile": "^6.0.0",
		"json5": "^2.2.3",
		"stringify-object": "^6.0.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/js": "^10.0.1",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^25.7.0",
		"@types/stringify-object": "^4.0.5",
		"concurrently": "^9.2.1",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsonc": "^3.1.2",
		"eslint-plugin-markdown": "^5.1.0",
		"eslint-plugin-vitest": "^0.5.4",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"inflection": "^3.0.2",
		"isbinaryfile": "^6.0.0",
		"json5": "^2.2.3",
		"prettier": "^3.8.3",
		"prettier-plugin-organize-imports": "^4.3.0",
		"stringify-object": "^6.0.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.46.0",
		"vitest": "^4.1.7"
	}
}
